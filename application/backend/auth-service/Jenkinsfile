// Auth service deploy pipeline — build Docker image, push to ECR, roll out to EKS
//
// Jenkins agent needs: Docker, AWS CLI, kubectl
// AWS credential in Jenkins (e.g. aws-frontend-terraform):
//   ecr:GetAuthorizationToken, ecr:BatchCheckLayerAvailability, ecr:PutImage, ecr:InitiateLayerUpload, ecr:UploadLayerPart, ecr:CompleteLayerUpload
//   eks:DescribeCluster (for update-kubeconfig)
// EKS access: IAM principal must be in infrastructure/backend terraform.tfvars
//   cluster_admin_principal_arns (see backend README — kubectl access)

pipeline {
    agent {
        label 'terraform'
    }
    
    environment {
        EKS_CLUSTER = 'cdec-eks-dev'
        EKS_REGION = 'eu-north-1'
    }

    stages {

        stage('Checkout') {
            steps {
                git url: 'https://github.com/rohitarame/cdec-alpha-app1.git', branch: 'main'
            }
        }

        stage('Build Docker image') {
            agent {
                label 'master'
            }
            steps {
                dir('application/backend/auth-service') {
                    sh '''
                        docker build -t 138035228373.dkr.ecr.eu-north-1.amazonaws.com/backend/auth-service:latest .
                    '''
                }
            }
        }

        stage('Push to ECR') {
            agent {
                label 'master'
            }
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-credentials',
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    sh '''
                        export AWS_DEFAULT_REGION=eu-north-1
                        aws ecr get-login-password --region eu-north-1 | \
                            docker login --username AWS --password-stdin 138035228373.dkr.ecr.eu-north-1.amazonaws.com
                        docker push 138035228373.dkr.ecr.eu-north-1.amazonaws.com/backend/auth-service:latest
                    '''
                }
            }
        }

        stage('Deploy to EKS') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-credentials',
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    dir('application/backend/auth-service') {
                        sh '''
                            export AWS_DEFAULT_REGION=${EKS_REGION}
                            aws eks update-kubeconfig --region ${EKS_REGION} --name ${EKS_CLUSTER}

                            kubectl apply -f k8s/deployment.yml -n default
                            kubectl rollout restart deployment/auth-service -n default
                            kubectl rollout status deployment/auth-service -n default --timeout=300s
                        '''
                    }
                }
            }
        }
    }

    post {
        success {
            echo 'auth-service deployed successfully!'
        }
        failure {
            echo 'auth-service deployment failed. Check the stage logs above.'
        }
    }
}
